---
import { ArrowUpRight, Circle, MapPin, MessageCircle, Phone } from "@lucide/astro";
import Brand from "../components/Brand.astro";
import { site } from "../data/site.tr";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  activePath?: string;
}

const { title, description, activePath = Astro.url.pathname } = Astro.props;
const isActive = (href: string) => activePath === href || Astro.url.pathname === href;
---

<BaseLayout title={title} description={description}>
  <a class="skip-link" href="#main">{site.ui.skipLink}</a>

  <div class="announcement" role="note">
    <div class="shell announcement-inner">
      <span><Circle aria-hidden="true" size={7} fill="currentColor" strokeWidth={0} /> {site.ui.announcementText}</span>
      <a href={site.phone.href}>{site.ui.announcementCta}</a>
    </div>
  </div>

  <header class="site-header">
    <div class="shell header-inner">
      <Brand />
      <nav class="desktop-nav" aria-label={site.ui.mainNavAriaLabel}>
        {site.nav.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </nav>
      <a class="button button-small header-cta" href={site.whatsapp.href}>
        {site.ui.appointmentCta} <ArrowUpRight aria-hidden="true" size={15} />
      </a>
      <details class="mobile-menu">
        <summary aria-label={site.ui.mobileMenuLabel}>{site.ui.mobileMenuLabel}</summary>
        <nav aria-label={site.ui.mobileNavAriaLabel}>
          {site.nav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
          ))}
          <a href={site.whatsapp.href}>{site.ui.appointmentCta}</a>
        </nav>
      </details>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="shell footer-main">
      <div>
        <Brand />
        <p>{site.ui.footerDescription}</p>
      </div>
      <div class="footer-links">
        <div><h3>{site.ui.footerExploreHeading}</h3>{site.nav.slice(0, 4).map((item) => <a href={item.href}>{item.label}</a>)}</div>
        <div><h3>{site.ui.footerContactHeading}</h3><a href={site.phone.href}>{site.phone.label}</a><a href={site.whatsapp.href}>{site.ui.whatsappLabel}</a><a href={site.address.maps}>{site.ui.directionsLabel}</a></div>
      </div>
    </div>
    <div class="shell footer-bottom">
      <p>© {new Date().getFullYear()} {site.ui.footerCopyrightName}</p>
      <p>{site.ui.footerTagline}</p>
    </div>
  </footer>

  <nav class="mobile-action-bar" aria-label={site.ui.mobileActionAriaLabel}>
    <a href={site.phone.href}><Phone aria-hidden="true" size={16} />{site.ui.mobileActions.phone}</a>
    <a href={site.whatsapp.href}><MessageCircle aria-hidden="true" size={16} />{site.ui.mobileActions.whatsapp}</a>
    <a href={site.address.maps}><MapPin aria-hidden="true" size={16} />{site.ui.mobileActions.directions}</a>
  </nav>
</BaseLayout>
