---
import { getEntry } from "astro:content";
import { ArrowUpRight, Plus } from "@lucide/astro";
import LineBreakText from "../../components/LineBreakText.astro";
import { faqs, site } from "../../data/site.tr";
import SiteLayout from "../../layouts/SiteLayout.astro";

const page = await getEntry("pages", "tr/sss");
if (!page) throw new Error("Türkçe sık sorulanlar sayfası içeriği bulunamadı.");
if (!page.data.faqPage) throw new Error("Türkçe sık sorulanlar detayları bulunamadı.");
---

<SiteLayout title={page.data.title} description={page.data.description} activePath="/sss/">
  <section class="section faq-section">
    <div class="shell faq-grid">
      <div class="faq-heading">
        <h1><LineBreakText text={page.data.hero.heading} /></h1>
        <p>{page.data.hero.text}</p>
        <a class="text-button" href={site.whatsapp.href}>{page.data.faqPage.ctaLabel} <ArrowUpRight aria-hidden="true" size={15} /></a>
      </div>
      <div class="faq-list">
        {faqs.map((faq, index) => (
          <details open={index === 0}>
            <summary><span>{String(index + 1).padStart(2, "0")}</span>{faq.question}<b aria-hidden="true"><Plus size={20} /></b></summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
