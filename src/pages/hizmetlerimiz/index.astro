---
import { getCollection, getEntry } from "astro:content";
import { ArrowUpRight } from "@lucide/astro";
import { site } from "../../data/site.tr";
import SiteLayout from "../../layouts/SiteLayout.astro";

const page = await getEntry("pages", "tr/hizmetlerimiz");
if (!page) throw new Error("Türkçe hizmetlerimiz sayfası içeriği bulunamadı.");
if (!page.data.serviceList) throw new Error("Türkçe hizmetlerimiz kart ayarları bulunamadı.");

const serviceList = await getEntry("serviceLists", "tr/services");
if (!serviceList) throw new Error("Türkçe hizmet sıralaması bulunamadı.");

const serviceEntries = await getCollection("services", ({ id }) => id.startsWith("tr/"));
const servicesById = new Map(serviceEntries.map((service) => [service.id, service]));
const orderedIds = serviceList.data.services.map((serviceId) => `tr/${serviceId}`);

if (new Set(orderedIds).size !== orderedIds.length) {
  throw new Error("Hizmet sıralamasında aynı hizmet birden fazla kez kullanılmış.");
}

const services = orderedIds.map((serviceId) => {
  const service = servicesById.get(serviceId);
  if (!service) throw new Error(`Hizmet sıralamasındaki \"${serviceId}\" içeriği bulunamadı.`);
  return service;
});

const unlistedServices = serviceEntries.filter((service) => !orderedIds.includes(service.id));
if (unlistedServices.length > 0) {
  throw new Error(`Sıralamaya eklenmemiş hizmetler var: ${unlistedServices.map(({ id }) => id).join(", ")}`);
}
---

<SiteLayout title={page.data.title} description={page.data.description} activePath="/hizmetlerimiz/">
  <section class="section services-section">
    <div class="shell">
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-card-image">
              <img
                src={service.data.image}
                alt={service.data.imageAlt}
                width="1200"
                height="800"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3>{service.data.title}</h3>
            <p>{service.data.description}</p>
            <a
              href={site.whatsapp.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${service.data.title} ${page.data.serviceList.ctaAriaSuffix}`}
            >
              {page.data.serviceList.ctaLabel} <ArrowUpRight aria-hidden="true" size={15} />
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
