---
import { getCollection } from "astro:content";
import { site } from "../../data/site.tr";
import SiteLayout from "../../layouts/SiteLayout.astro";

const services = (await getCollection("services", ({ id }) => id.startsWith("tr/")))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title="Hizmetler | Vet Area" description="Vet Area'nın muayene, koruyucu sağlık, laboratuvar, görüntüleme, cerrahi ve mikroçip hizmetleri." activePath="/hizmetler/">
  <section class="page-hero">
    <div class="shell page-hero-inner">
      <p class="eyebrow"><span aria-hidden="true">●</span> Hizmetlerimiz</p>
      <h1>Her yaşam evresine özenli destek.</h1>
      <p>İlk kontrolden ileri tanı süreçlerine kadar ihtiyaca odaklanır, her adımı anlaşılır biçimde paylaşırız.</p>
    </div>
  </section>

  <section class="section services-section">
    <div class="shell">
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <span>{String(service.data.order).padStart(2, "0")}</span>
            <h3>{service.data.title}</h3>
            <p>{service.data.description}</p>
            <a href={site.whatsapp.href} aria-label={`${service.data.title} için bilgi alın`}>
              Bilgi alın <b aria-hidden="true">↗</b>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
