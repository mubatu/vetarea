---
import { getCollection, getEntry } from "astro:content";
import { ArrowUpRight, Circle } from "@lucide/astro";
import { site } from "../../data/site.tr";
import SiteLayout from "../../layouts/SiteLayout.astro";

const page = await getEntry("pages", "tr/hizmetler");
if (!page) throw new Error("Türkçe hizmetler sayfası içeriği bulunamadı.");
if (!page.data.serviceList) throw new Error("Türkçe hizmetler kart ayarları bulunamadı.");

const services = (await getCollection("services", ({ id }) => id.startsWith("tr/")))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title={page.data.title} description={page.data.description} activePath="/hizmetler/">
  <section class="page-hero">
    <div class="shell page-hero-inner">
      <p class="eyebrow"><Circle aria-hidden="true" size={9} fill="currentColor" strokeWidth={0} /> {page.data.hero.eyebrow}</p>
      <h1>{page.data.hero.heading}</h1>
      <p>{page.data.hero.text}</p>
    </div>
  </section>

  <section class="section services-section">
    <div class="shell">
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <span>{String(service.data.order).padStart(2, "0")}</span>
            <h3>{service.data.title}</h3>
            <p>{service.data.description}</p>
            <a href={site.whatsapp.href} aria-label={`${service.data.title} ${page.data.serviceList.ctaAriaSuffix}`}>
              {page.data.serviceList.ctaLabel} <ArrowUpRight aria-hidden="true" size={15} />
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
