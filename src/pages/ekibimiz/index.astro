---
import { getCollection, getEntry } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

const page = await getEntry("pages", "tr/ekibimiz");
if (!page) throw new Error("Türkçe ekibimiz sayfası içeriği bulunamadı.");

const team = (await getCollection("team", ({ id }) => id.startsWith("tr/")))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title={page.data.title} description={page.data.description} activePath="/ekibimiz/">
  <section class="page-hero">
    <div class="shell page-hero-inner">
      <p class="eyebrow"><span aria-hidden="true">●</span> {page.data.hero.eyebrow}</p>
      <h1>{page.data.hero.heading}</h1>
      <p>{page.data.hero.text}</p>
    </div>
  </section>

  <section class="section team-section">
    <div class="shell">
      <div class="team-grid">
        {team.map((member, index) => (
          <article class:list={["team-card", index % 2 === 0 ? "team-card-red" : "team-card-blue"]}>
            <div class="team-initial">{member.data.initials}</div>
            <div><p>{member.data.role}</p><h3>{member.data.name}</h3></div>
            <span aria-hidden="true">{String(member.data.order).padStart(2, "0")}</span>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
