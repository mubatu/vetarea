---
import { getEntry } from "astro:content";
import { ArrowUpRight, Circle } from "@lucide/astro";
import LineBreakText from "../../components/LineBreakText.astro";
import { site } from "../../data/site.tr";
import SiteLayout from "../../layouts/SiteLayout.astro";

const page = await getEntry("pages", "tr/iletisim");
if (!page) throw new Error("Türkçe iletişim sayfası içeriği bulunamadı.");
if (!page.data.contact) throw new Error("Türkçe iletişim detayları bulunamadı.");
---

<SiteLayout title={page.data.title} description={page.data.description} activePath="/iletisim/">
  <section class="section contact-section">
    <div class="shell contact-grid">
      <div class="contact-copy">
        <p class="eyebrow light"><Circle aria-hidden="true" size={9} fill="currentColor" strokeWidth={0} /> {page.data.hero.eyebrow}</p>
        <h1><LineBreakText text={page.data.hero.heading} /></h1>
        <p>{page.data.contact.intro}</p>
        <div class="contact-actions">
          <a class="button button-white" href={site.phone.href}>{page.data.contact.phoneCtaLabel} <ArrowUpRight aria-hidden="true" size={16} /></a>
          <a class="button button-outline-light" href={site.whatsapp.href}>{page.data.contact.whatsappCtaLabel}</a>
        </div>
        <dl class="contact-list">
          <div><dt>{page.data.contact.labels.phone}</dt><dd><a href={site.phone.href}>{site.phone.label}</a></dd></div>
          <div><dt>{page.data.contact.labels.hours}</dt><dd>{site.hours}</dd></div>
          <div><dt>{page.data.contact.labels.address}</dt><dd>{site.address.full}</dd></div>
        </dl>
      </div>
      <div class="map-card">
        <iframe title={page.data.contact.mapTitle} src={site.address.embed} loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        <a href={site.address.maps}>
          <span><small>{page.data.contact.mapSmall}</small><strong>{page.data.contact.mapStrong}</strong></span>
          <ArrowUpRight aria-hidden="true" size={15} />
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
