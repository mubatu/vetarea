---
import { getCollection, getEntry } from "astro:content";
import { site } from "../data/site.tr";
import SiteLayout from "../layouts/SiteLayout.astro";

const home = await getEntry("pages", "tr/ana-sayfa");
if (!home) throw new Error("Türkçe ana sayfa içeriği bulunamadı.");

const team = (await getCollection("team", ({ id }) => id.startsWith("tr/")))
  .sort((a, b) => a.data.order - b.data.order);

const heroImage =
  "https://images.unsplash.com/photo-1770836037289-e00e5f351d11?auto=format&fit=crop&fm=jpg&q=84&w=1800";
---

<SiteLayout title={home.data.title} description={home.data.description} activePath="/">
  <section class="hero" id="top">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><span aria-hidden="true">●</span> {home.data.hero.eyebrow}</p>
        <h1>{home.data.hero.heading}<br /> <em>{home.data.hero.highlight}</em></h1>
        <p class="hero-lead">{home.data.hero.text}</p>
        <div class="hero-actions">
          <a class="button" href={site.whatsapp.href}>
            Randevu oluştur <span aria-hidden="true">↗</span>
          </a>
          <a class="text-link" href={site.phone.href}>
            <span class="link-icon" aria-hidden="true">☎</span>
            <span>Bizi arayın<strong>{site.phone.label}</strong></span>
          </a>
        </div>
        <div class="hero-note">
          <span class="avatar-stack" aria-hidden="true">
            {team.map((member) => <b>{member.data.initials}</b>)}<b>+</b>
          </span>
          <p><strong>Güvendiğiniz ekip,</strong><br /> ihtiyaç duyduğunuz anda burada.</p>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-image-wrap">
          <img src={heroImage} alt={home.data.hero.imageAlt} fetchpriority="high" />
        </div>
        <div class="open-card">
          <span class="open-icon" aria-hidden="true">+</span>
          <span><small>Kesintisiz hizmet</small><strong>7 / 24 Açığız</strong></span>
        </div>
        <div class="paw-dots" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
      </div>
    </div>
  </section>

  <section class="trust-bar" aria-label="Klinik bilgileri">
    <div class="shell trust-grid">
      <a href={site.phone.href}>
        <span class="trust-number">7/24</span>
        <span><strong>Kesintisiz ulaşın</strong><small>Acil durumlarda önce arayın</small></span>
        <b aria-hidden="true">↗</b>
      </a>
      <a href="/ekibimiz/">
        <span class="trust-number">02</span>
        <span><strong>Tanıdığınız hekimler</strong><small>Şeffaf ve sakin iletişim</small></span>
        <b aria-hidden="true">↗</b>
      </a>
      <a href={site.address.maps}>
        <span class="trust-number">06</span>
        <span><strong>Emek, Çankaya</strong><small>Merkezi ve kolay ulaşım</small></span>
        <b aria-hidden="true">↗</b>
      </a>
    </div>
  </section>

  <section class="section explore-section" aria-labelledby="explore-title">
    <div class="shell">
      <div class="section-heading split-heading">
        <div>
          <p class="eyebrow dark"><span aria-hidden="true">●</span> Vet Area</p>
          <h2 id="explore-title">İhtiyacınız olan sayfaya geçin.</h2>
        </div>
        <p>Hizmetler, ekip, randevu ve sık sorulan sorular artık ayrı sayfalarda daha rahat okunur.</p>
      </div>
      <div class="page-link-grid">
        {site.nav.map((item, index) => (
          <a class="page-link-card" href={item.href}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item.label}</strong>
            <b aria-hidden="true">↗</b>
          </a>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
