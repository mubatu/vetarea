---
import { getCollection, getEntry } from "astro:content";
import Brand from "../components/Brand.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqs, site } from "../data/site.tr";

const home = await getEntry("pages", "tr/ana-sayfa");
if (!home) throw new Error("Türkçe ana sayfa içeriği bulunamadı.");

const services = (await getCollection("services", ({ id }) => id.startsWith("tr/")))
  .sort((a, b) => a.data.order - b.data.order);
const team = (await getCollection("team", ({ id }) => id.startsWith("tr/")))
  .sort((a, b) => a.data.order - b.data.order);

const heroImage =
  "https://images.unsplash.com/photo-1770836037289-e00e5f351d11?auto=format&fit=crop&fm=jpg&q=84&w=1800";
const catImage =
  "https://images.unsplash.com/photo-1733783506192-653df6185a7d?auto=format&fit=crop&fm=jpg&q=84&w=1400";
---

<BaseLayout title={home.data.title} description={home.data.description}>
  <a class="skip-link" href="#main">İçeriğe geç</a>

  <div class="announcement" role="note">
    <div class="shell announcement-inner">
      <span><i aria-hidden="true"></i> Emek&apos;te 7 gün, 24 saat yanınızdayız</span>
      <a href={site.phone.href}>Acil durumlar için arayın</a>
    </div>
  </div>

  <header class="site-header">
    <div class="shell header-inner">
      <Brand />
      <nav class="desktop-nav" aria-label="Ana menü">
        {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <a class="button button-small header-cta" href={site.whatsapp.href}>
        Randevu al <span aria-hidden="true">↗</span>
      </a>
      <details class="mobile-menu">
        <summary aria-label="Menüyü aç">Menü</summary>
        <nav aria-label="Mobil menü">
          {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href={site.whatsapp.href}>Randevu al</a>
        </nav>
      </details>
    </div>
  </header>

  <main id="main">
    <section class="hero" id="top">
      <div class="shell hero-grid">
        <div class="hero-copy">
          <p class="eyebrow"><span aria-hidden="true">●</span> {home.data.hero.eyebrow}</p>
          <h1>{home.data.hero.heading}<br /> <em>{home.data.hero.highlight}</em></h1>
          <p class="hero-lead">{home.data.hero.text}</p>
          <div class="hero-actions">
            <a class="button" href={site.whatsapp.href}>
              Randevu oluştur <span aria-hidden="true">↗</span>
            </a>
            <a class="text-link" href={site.phone.href}>
              <span class="link-icon" aria-hidden="true">☎</span>
              <span>Bizi arayın<strong>{site.phone.label}</strong></span>
            </a>
          </div>
          <div class="hero-note">
            <span class="avatar-stack" aria-hidden="true">
              {team.map((member) => <b>{member.data.initials}</b>)}<b>+</b>
            </span>
            <p><strong>Güvendiğiniz ekip,</strong><br /> ihtiyaç duyduğunuz anda burada.</p>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-image-wrap">
            <img src={heroImage} alt={home.data.hero.imageAlt} fetchpriority="high" />
          </div>
          <div class="open-card">
            <span class="open-icon" aria-hidden="true">+</span>
            <span><small>Kesintisiz hizmet</small><strong>7 / 24 Açığız</strong></span>
          </div>
          <div class="paw-dots" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
        </div>
      </div>
    </section>

    <section class="trust-bar" aria-label="Klinik bilgileri">
      <div class="shell trust-grid">
        <a href={site.phone.href}>
          <span class="trust-number">7/24</span>
          <span><strong>Kesintisiz ulaşın</strong><small>Acil durumlarda önce arayın</small></span>
          <b aria-hidden="true">↗</b>
        </a>
        <a href="#ekibimiz">
          <span class="trust-number">02</span>
          <span><strong>Tanıdığınız hekimler</strong><small>Şeffaf ve sakin iletişim</small></span>
          <b aria-hidden="true">↓</b>
        </a>
        <a href={site.address.maps}>
          <span class="trust-number">06</span>
          <span><strong>Emek, Çankaya</strong><small>Merkezi ve kolay ulaşım</small></span>
          <b aria-hidden="true">↗</b>
        </a>
      </div>
    </section>

    <section class="section services-section" id="hizmetler">
      <div class="shell">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow dark"><span aria-hidden="true">●</span> Hizmetlerimiz</p>
            <h2>Her yaşam evresine<br />özenli destek.</h2>
          </div>
          <p>İlk kontrolden ileri tanı süreçlerine kadar ihtiyaca odaklanır, her adımı anlaşılır biçimde paylaşırız.</p>
        </div>

        <div class="services-grid">
          {services.map((service) => (
            <article class="service-card">
              <span>{String(service.data.order).padStart(2, "0")}</span>
              <h3>{service.data.title}</h3>
              <p>{service.data.description}</p>
              <a href={site.whatsapp.href} aria-label={`${service.data.title} için bilgi alın`}>
                Bilgi alın <b aria-hidden="true">↗</b>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section about-section" id="hakkimizda">
      <div class="shell about-grid">
        <div class="about-visual">
          <img src={catImage} alt="Veteriner hekim tarafından muayene edilen beyaz bir kedi" loading="lazy" />
          <p class="image-caption">Sakin yaklaşım, dikkatli muayene.</p>
        </div>
        <div class="about-copy">
          <p class="eyebrow light"><span aria-hidden="true">●</span> Vet Area hakkında</p>
          <h2>Aynı dikkat,<br />her ziyarette.</h2>
          <p class="about-lead">Kliniğe gelen her dostun kendine özgü olduğunu biliyoruz. Bu yüzden önce dinler, sonra muayene eder ve seçenekleri sizinle birlikte değerlendiririz.</p>
          <div class="principles">
            <div><span>01</span><p><strong>Açık iletişim</strong>Tedavi sürecini anlaşılır şekilde paylaşırız.</p></div>
            <div><span>02</span><p><strong>Bireysel yaklaşım</strong>Her planı dostunuzun ihtiyacına göre oluştururuz.</p></div>
            <div><span>03</span><p><strong>Süreklilik</strong>Kontrolden takibe aynı özenle yanınızda oluruz.</p></div>
          </div>
          <a class="button button-light" href={site.whatsapp.href}>Bizimle tanışın <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </section>

    <section class="section team-section" id="ekibimiz">
      <div class="shell">
        <div class="section-heading centered-heading">
          <p class="eyebrow dark"><span aria-hidden="true">●</span> Ekibimiz</p>
          <h2>Dostunuz emin ellerde.</h2>
          <p>Dinleyen, açıklayan ve süreci birlikte yöneten bir ekip.</p>
        </div>
        <div class="team-grid">
          {team.map((member, index) => (
            <article class:list={["team-card", index % 2 === 0 ? "team-card-red" : "team-card-blue"]}>
              <div class="team-initial">{member.data.initials}</div>
              <div><p>{member.data.role}</p><h3>{member.data.name}</h3></div>
              <span aria-hidden="true">{String(member.data.order).padStart(2, "0")}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section contact-section" id="iletisim">
      <div class="shell contact-grid">
        <div class="contact-copy">
          <p class="eyebrow light"><span aria-hidden="true">●</span> İletişim</p>
          <h2>Bir telefon<br />kadar yakınız.</h2>
          <p>Randevu, acil durum ya da aklınıza takılanlar için bize ulaşın. Gelmeden önce aramanız, en doğru hazırlığı yapmamıza yardımcı olur.</p>
          <div class="contact-actions">
            <a class="button button-white" href={site.phone.href}>Hemen ara <span aria-hidden="true">↗</span></a>
            <a class="button button-outline-light" href={site.whatsapp.href}>WhatsApp</a>
          </div>
          <dl class="contact-list">
            <div><dt>Telefon</dt><dd><a href={site.phone.href}>{site.phone.label}</a></dd></div>
            <div><dt>Çalışma saatleri</dt><dd>{site.hours}</dd></div>
            <div><dt>Adres</dt><dd>{site.address.full}</dd></div>
          </dl>
        </div>
        <div class="map-card">
          <iframe title="Vet Area konumu" src="https://www.google.com/maps?q=VetArea%20Emek%20Veteriner%20Klini%C4%9Fi&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          <a href={site.address.maps}>
            <span><small>Vet Area</small><strong>Yol tarifi alın</strong></span>
            <b aria-hidden="true">↗</b>
          </a>
        </div>
      </div>
    </section>

    <section class="section faq-section" id="sss">
      <div class="shell faq-grid">
        <div class="faq-heading">
          <p class="eyebrow dark"><span aria-hidden="true">●</span> Sık sorulanlar</p>
          <h2>Gelmeden önce<br />merak ettikleriniz.</h2>
          <p>Yanıtını bulamadığınız bir konu varsa bize dilediğiniz zaman ulaşabilirsiniz.</p>
          <a class="text-button" href={site.whatsapp.href}>Bize sorun <span aria-hidden="true">↗</span></a>
        </div>
        <div class="faq-list">
          {faqs.map((faq, index) => (
            <details open={index === 0}>
              <summary><span>{String(index + 1).padStart(2, "0")}</span>{faq.question}<b aria-hidden="true">+</b></summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="shell footer-main">
      <div>
        <Brand />
        <p>Dostlarınız için modern, güvenilir ve ulaşılabilir veteriner hizmeti.</p>
      </div>
      <div class="footer-links">
        <div><h3>Keşfedin</h3>{site.nav.slice(0, 4).map((item) => <a href={item.href}>{item.label}</a>)}</div>
        <div><h3>Ulaşın</h3><a href={site.phone.href}>{site.phone.label}</a><a href={site.whatsapp.href}>WhatsApp</a><a href={site.address.maps}>Yol tarifi</a></div>
      </div>
    </div>
    <div class="shell footer-bottom">
      <p>© {new Date().getFullYear()} Vet Area Emek Veteriner Kliniği</p>
      <p>Emek&apos;te dostlarınız için, her gün.</p>
    </div>
  </footer>

  <nav class="mobile-action-bar" aria-label="Hızlı iletişim">
    <a href={site.phone.href}><span aria-hidden="true">☎</span>Ara</a>
    <a href={site.whatsapp.href}><span aria-hidden="true">●</span>WhatsApp</a>
    <a href={site.address.maps}><span aria-hidden="true">⌖</span>Yol tarifi</a>
  </nav>
</BaseLayout>
