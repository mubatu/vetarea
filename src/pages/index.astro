---
import { getEntry } from "astro:content";
import { MapPin, Phone, Plus, SquareArrowOutUpRight, Users } from "@lucide/astro";
import { site } from "../data/site.tr";
import SiteLayout from "../layouts/SiteLayout.astro";

const home = await getEntry("pages", "tr/ana-sayfa");
if (!home) throw new Error("Türkçe ana sayfa içeriği bulunamadı.");
if (!home.data.home) throw new Error("Türkçe ana sayfa detayları bulunamadı.");

const getSharedHref = (href: string) => {
  if (href === "phone") return site.phone.href;
  if (href === "maps") return site.address.maps;
  return href;
};
---

<SiteLayout title={home.data.title} description={home.data.description} activePath="/">
  <section class="hero" id="top">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <h1>{home.data.hero.heading}<br /> <em>{home.data.hero.highlight}</em></h1>
        <p class="hero-lead">{home.data.hero.text}</p>
        <div class="hero-actions">
          <a class="button" href={site.whatsapp.href} target="_blank" rel="noopener noreferrer">
            {home.data.home.primaryActionLabel} <SquareArrowOutUpRight aria-hidden="true" size={16} />
          </a>
          <a class="text-link" href={site.phone.href}>
            <span class="link-icon" aria-hidden="true"><Phone size={16} /></span>
            <span>{home.data.home.phoneActionLabel}<strong>{site.phone.label}</strong></span>
          </a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-image-wrap">
          <img src={home.data.hero.image} alt={home.data.hero.imageAlt} fetchpriority="high" />
        </div>
        <div class="open-card">
          <span class="open-icon" aria-hidden="true"><Plus size={25} /></span>
          <span><small>{home.data.home.statusSmall}</small><strong>{home.data.home.statusStrong}</strong></span>
        </div>
        <div class="paw-dots" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
      </div>
    </div>
  </section>

  <section class="trust-bar" aria-label={home.data.home.trustAriaLabel}>
    <div class="shell trust-grid">
      {home.data.home.trust.map((item) => (
        <a href={getSharedHref(item.href)}>
          <span class="trust-number">
            {item.icon === "users" && <Users aria-hidden="true" size={18} />}
            {item.icon === "map-pin" && <MapPin aria-hidden="true" size={18} />}
            {!item.icon && item.number}
          </span>
          <span><strong>{item.title}</strong><small>{item.text}</small></span>
          <SquareArrowOutUpRight aria-hidden="true" size={15} />
        </a>
      ))}
    </div>
  </section>
</SiteLayout>
